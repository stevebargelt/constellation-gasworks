# =============================================================================
# LOCAL DEV — Supabase CLI (http://127.0.0.1:54321)
# Get these values from `supabase status` after running `supabase start`
# =============================================================================
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role key — required for pnpm seed (sb_secret_xxx from `supabase status`)
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# SELF-HOSTED SUPABASE ON AZURE (https://constellation.db.harebrained-apps.com)
# Uncomment and populate this section to target the self-hosted VM instance.
# Replace <anon-key> with the value from your Supabase dashboard or Key Vault.
# =============================================================================
# VITE_SUPABASE_URL=https://constellation.db.harebrained-apps.com
# VITE_SUPABASE_PUBLISHABLE_KEY=<anon-key>
# EXPO_PUBLIC_SUPABASE_URL=https://constellation.db.harebrained-apps.com
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<anon-key>

# =============================================================================
# OBSERVABILITY — New Relic + PostHog
# Populate these when running against a non-local environment.
# Leave blank to disable (guarded at init time in apps/web and apps/mobile).
# =============================================================================
VITE_NEW_RELIC_APP_ID=
VITE_NEW_RELIC_LICENSE_KEY=
VITE_POSTHOG_KEY=
EXPO_PUBLIC_NEW_RELIC_APP_TOKEN=
EXPO_PUBLIC_POSTHOG_KEY=
