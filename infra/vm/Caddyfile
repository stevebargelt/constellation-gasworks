# =============================================================================
# Caddyfile — Supabase on Azure VM
# Deployed to: /etc/caddy/Caddyfile (by cloud-init)
#
# Each Supabase project needs two blocks:
#   1. API block  — routes <project>.db.harebrained-apps.com to Kong (port 8N00)
#   2. Studio block — routes studio.<project>.db.harebrained-apps.com to Studio (port 3N00)
#
# TLS is handled automatically via Let's Encrypt ACME — no manual cert management.
# HTTP → HTTPS redirect is automatic for all named sites (Caddy default behavior).
# The VM's static IP must be pointed to by a wildcard A record:
#   *.db.harebrained-apps.com → <VM static IP>
#
# Port allocation scheme (N = project index, starting at 0):
#   Project 0 (constellation): Kong=8000, Studio=3000
#   Project 1 (proto-a):       Kong=8100, Studio=3100
#   Project 2 (proto-b):       Kong=8200, Studio=3200
#   ... and so on.
# =============================================================================

# =============================================================================
# PROJECT: constellation  (index 0 — Kong=8000, Studio=3000)
# =============================================================================

constellation.db.harebrained-apps.com {
	reverse_proxy localhost:8000
}

studio.constellation.db.harebrained-apps.com {
	reverse_proxy localhost:3000
}

# =============================================================================
# HOW TO ADD A NEW PROJECT
# =============================================================================
# 1. Copy the two blocks below (uncomment + fill in values).
# 2. Set SUBDOMAIN to the project name (e.g., proto-a).
# 3. Set KONG_PORT to 8N00 and STUDIO_PORT to 3N00 where N is the next index.
# 4. Reload Caddy: systemctl reload caddy
# 5. Caddy will automatically obtain a TLS certificate via ACME.
#
# Example — project "proto-a" (index 1):
#
# proto-a.db.harebrained-apps.com {
# 	reverse_proxy localhost:8100
# }
#
# studio.proto-a.db.harebrained-apps.com {
# 	reverse_proxy localhost:3100
# }
# =============================================================================
