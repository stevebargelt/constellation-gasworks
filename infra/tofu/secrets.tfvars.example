# secrets.tfvars.example — Required sensitive variable names for OpenTofu
#
# DO NOT commit real values. This file shows variable names only.
#
# In CI (GitHub Actions), these are set as TF_VAR_* secrets:
#   TF_VAR_constellation_jwt_secret         = "..."
#   TF_VAR_constellation_postgres_password  = "..."
#   TF_VAR_constellation_anon_key           = "..."
#   TF_VAR_constellation_service_role_key   = "..."
#   TF_VAR_resend_api_key                   = "..."
#   TF_VAR_vm_ssh_public_key                = "..."
#   TF_VAR_tfstate_storage_account          = "..."
#
# For local runs, copy this file to secrets.tfvars (gitignored) and fill in values:
#   tofu plan -var-file=secrets.tfvars
#
# HOW TO GENERATE SECRETS
# ------------------------
# JWT secret (shared across all Supabase tokens):
#   openssl rand -hex 32
#
# Postgres password:
#   openssl rand -base64 32
#
# Anon key + service role key (JWTs signed with JWT_SECRET):
#   Follow: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
#   Use the JWT_SECRET generated above as the signing key.
#
# Resend API key:
#   https://resend.com — create account, generate API key under Settings > API Keys

constellation_jwt_secret        = "REPLACE_ME_openssl_rand_hex_32"
constellation_postgres_password = "REPLACE_ME_openssl_rand_base64_32"
constellation_anon_key          = "REPLACE_ME_supabase_anon_jwt"
constellation_service_role_key  = "REPLACE_ME_supabase_service_role_jwt"
resend_api_key                  = "REPLACE_ME_resend_api_key"

# Non-secret but required:
vm_ssh_public_key      = "REPLACE_ME_ssh_public_key_string"
tfstate_storage_account = "REPLACE_ME_storage_account_name"
