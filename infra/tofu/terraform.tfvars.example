# terraform.tfvars.example
# Copy to terraform.tfvars (gitignored) and fill in values before running tofu apply.
# Sensitive values (ssh public key, etc.) can also be passed as TF_VAR_* env vars in CI.

project_name            = "constellation"
resource_group_name     = "rg-constellation"
location                = "eastus"
environment             = "production"
dns_zone_name           = "db.harebrained-apps.com"
tfstate_storage_account = "stconstellationtfstate"   # Must match bootstrapped account name
vm_admin_username       = "azureuser"

# vm_ssh_public_key — provide via TF_VAR_vm_ssh_public_key in CI, or set here for local runs
# vm_ssh_public_key = "ssh-ed25519 AAAA... user@host"

# vm_custom_data — base64-encoded cloud-init YAML; generated by:
#   base64 -w0 infra/vm/cloud-init.yaml
# Leave null to provision the VM without cloud-init (manual setup required)
# vm_custom_data = null
